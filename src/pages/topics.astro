---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Card from '../components/ui/Card.astro';
import CardHeader from '../components/ui/CardHeader.astro';
import CardTitle from '../components/ui/CardTitle.astro';
import CardDescription from '../components/ui/CardDescription.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import { getCategoryColors } from '../components/CategoryColors.astro';
import { formatTopicDate, getRecentTopics } from '../utils/recent-topics';

const topics = await getCollection('topics');
const sortedTopics = topics.sort((a, b) => a.data.title.localeCompare(b.data.title));
const recentTopics = getRecentTopics(topics, 5);

// Get unique categories from actual content
const availableCategories = [...new Set(topics.map(t => t.data.category))].sort();
const totalTopics = sortedTopics.length;
const mitreMappedTopicsCount = topics.filter((topic) =>
  Array.isArray(topic.data.mitreTechniques) && topic.data.mitreTechniques.length > 0
).length;
const offensiveCount = topics.filter((topic) =>
  topic.data.category.toLowerCase() === 'offensive'
).length;
const defensiveCount = topics.filter((topic) =>
  topic.data.category.toLowerCase() === 'defensive'
).length;
---

<BaseLayout
  title="Topics - Kubernetes Security"
  description="Reference materials covering offensive and defensive Kubernetes security techniques, with impact and mitigation for each topic."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
    <div class="mb-10">
      <div class="rounded-2xl border border-gray-200/80 bg-gradient-to-b from-white to-gray-50/60 p-6 sm:p-8 dark:border-zinc-800 dark:from-zinc-900 dark:to-zinc-900/40">
        <div class="flex items-center gap-3 mb-4">
          <div class="text-primary-600">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-zinc-100">Topics</h1>
        </div>
        <p class="text-base sm:text-lg text-gray-600 dark:text-zinc-400 max-w-3xl">
          Reference materials covering offensive and defensive Kubernetes security techniques
        </p>

        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
          <div class="rounded-xl border border-gray-200 bg-white/90 px-4 py-4 dark:border-zinc-800 dark:bg-zinc-900/70">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold tracking-wide text-gray-500 dark:text-zinc-500">Total</p>
                <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-zinc-100">{totalTopics}</p>
              </div>
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-gray-100 text-gray-700 dark:bg-zinc-800 dark:text-zinc-300">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </span>
            </div>
          </div>
          <div class="rounded-xl border border-gray-200 bg-white/90 px-4 py-4 dark:border-zinc-800 dark:bg-zinc-900/70">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold tracking-wide text-gray-500 dark:text-zinc-500">MITRE ATT&CK mapped</p>
                <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-zinc-100">{mitreMappedTopicsCount}</p>
              </div>
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-gray-100 text-gray-700 dark:bg-zinc-800 dark:text-zinc-300">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.868v4.264a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </span>
            </div>
          </div>
          <div class="rounded-xl border border-gray-200 bg-white/90 px-4 py-4 dark:border-zinc-800 dark:bg-zinc-900/70">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold tracking-wide text-gray-500 dark:text-zinc-500">Offensive</p>
                <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-zinc-100">{offensiveCount}</p>
              </div>
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-rose-50 text-rose-600 dark:bg-rose-500/10 dark:text-rose-300">
                <CategoryIcon category="offensive" class="h-5 w-5" />
              </span>
            </div>
          </div>
          <div class="rounded-xl border border-gray-200 bg-white/90 px-4 py-4 dark:border-zinc-800 dark:bg-zinc-900/70">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold tracking-wide text-gray-500 dark:text-zinc-500">Defensive</p>
                <p class="mt-1 text-2xl font-semibold text-gray-900 dark:text-zinc-100">{defensiveCount}</p>
              </div>
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-sky-50 text-sky-600 dark:bg-sky-500/10 dark:text-sky-300">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3l7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4z" />
                </svg>
              </span>
            </div>
          </div>
        </div>
      </div>

      {recentTopics.length > 0 && (
        <div class="mt-6 rounded-2xl border border-gray-200/90 bg-gradient-to-b from-gray-50/70 to-white px-5 py-5 shadow-sm dark:border-zinc-800 dark:from-zinc-900/40 dark:to-zinc-950 sm:px-6">
          <div class="border-b border-gray-200/80 pb-4 dark:border-zinc-800">
            <div class="flex items-start gap-3">
              <div class="text-primary-600 shrink-0">
                <svg class="w-7 h-7 sm:w-8 sm:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <div class="min-w-0">
                <h2 class="text-base font-semibold tracking-tight text-gray-900 dark:text-zinc-50">Recently added</h2>
                <p class="mt-1.5 text-sm leading-relaxed text-gray-600 dark:text-zinc-400">
                  Newest at the top. Each date is when that topic was first listed here.
                </p>
              </div>
            </div>
          </div>
          <ul class="mt-1 space-y-0.5 pt-1">
            {recentTopics.map((topic) => {
              const categoryColors = getCategoryColors(topic.data.category);
              return (
                <li>
                  <a
                    href={`/topics/${topic.slug}`}
                    class="group flex flex-col gap-1.5 rounded-lg px-2 py-2.5 -mx-2 transition-colors hover:bg-white/90 dark:hover:bg-zinc-800/70 sm:flex-row sm:items-center sm:justify-between sm:gap-6 sm:py-2.5"
                  >
                    <span class="text-sm font-medium leading-snug text-gray-900 group-hover:text-primary-700 dark:text-zinc-100 dark:group-hover:text-primary-400">
                      {topic.data.title}
                    </span>
                    <span class="flex shrink-0 items-center gap-2.5 text-xs tabular-nums sm:justify-end">
                      <span
                        class={`rounded-md px-2 py-0.5 capitalize ring-1 ring-inset ring-black/[0.06] dark:ring-white/[0.08] ${categoryColors.bg} ${categoryColors.text}`}
                      >
                        {topic.data.category}
                      </span>
                      <time
                        class="text-gray-500 dark:text-zinc-500"
                        datetime={topic.data.createdAt!.toISOString().slice(0, 10)}
                      >
                        {formatTopicDate(topic.data.createdAt!)}
                      </time>
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      )}

      <!-- Search Bar with Tag Filters -->
      <div class="mt-6 mb-6">
        <Card class="p-3 sm:p-4 rounded-xl">
          <!-- Search Input + reset -->
          <div class="flex items-center gap-2">
            <div class="relative min-w-0 flex-1">
              <input
                type="text"
                id="search-input"
                placeholder="Search topics..."
                class="w-full py-2 pl-9 pr-3 border border-gray-300 dark:border-zinc-700 rounded-md focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none text-[13px] leading-tight bg-white dark:bg-zinc-900 text-gray-900 dark:text-zinc-100"
              />
              <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-500 dark:text-zinc-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <button
              type="button"
              id="reset-filters-btn"
              class="hidden shrink-0 rounded-md border border-gray-200 bg-white px-2.5 py-2 text-[13px] font-medium text-gray-700 shadow-sm transition-colors hover:bg-gray-50 dark:border-zinc-600 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:bg-zinc-800"
              title="Clear search and category filters"
              aria-label="Reset search and filters"
            >
              Reset
            </button>
          </div>

          <!-- Filter by Tags (Collapsible) -->
          <div class="mt-2.5">
            <button
              type="button"
              id="filter-toggle-btn"
              class="group inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md border border-gray-200 bg-gray-50 text-xs font-medium text-gray-700 hover:bg-white hover:border-gray-300 dark:border-zinc-700 dark:bg-zinc-900/70 dark:text-zinc-300 dark:hover:bg-zinc-900 dark:hover:border-zinc-600 transition-colors"
              aria-expanded="false"
              aria-controls="filter-tags-content"
            >
              <svg class="w-3.5 h-3.5 text-gray-500 dark:text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
              </svg>
              <span>Filter by category</span>
              <span id="filter-selected-count" class="hidden items-center justify-center min-w-5 h-5 px-1.5 rounded-full bg-primary-100 text-primary-800 text-[11px] font-semibold dark:bg-primary-900/40 dark:text-primary-200"></span>
              <svg id="filter-toggle-icon" class="w-3.5 h-3.5 text-gray-500 dark:text-zinc-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div id="filter-tags-content" class="hidden pt-2">
              <div class="rounded-lg border border-gray-200/80 bg-gray-50/60 p-2.5 dark:border-zinc-700 dark:bg-zinc-900/40">
                <p class="text-[11px] text-gray-500 dark:text-zinc-400 mb-1.5">Choose one or more categories</p>
                <div class="flex flex-wrap gap-1.5">
                {availableCategories.map(category => {
                  const categoryColors = getCategoryColors(category);
                  return (
                    <button
                      type="button"
                      class={`tag-filter-btn inline-flex items-center gap-1.5 px-2.5 py-1 text-[11px] font-medium rounded-md border transition-all ${categoryColors.bg} ${categoryColors.text} ${categoryColors.border} hover:opacity-90 hover:-translate-y-0.5`}
                      data-tag-type="category"
                      data-tag-value={category}
                      data-tag-label={category.charAt(0).toUpperCase() + category.slice(1)}
                    >
                      <CategoryIcon category={category} class={`w-3 h-3 ${categoryColors.icon}`} />
                      {category.charAt(0).toUpperCase() + category.slice(1)}
                    </button>
                  );
                })}
                </div>
              </div>
            </div>
          </div>

          <!-- Active Filter Tags -->
          <div id="active-filters" class="mt-2 hidden">
            <div class="flex items-center gap-1.5 flex-wrap">
              <span class="text-[11px] text-gray-500 dark:text-zinc-500">Active:</span>
              <div id="active-filter-tags" class="flex flex-wrap gap-2">
              </div>
              <button id="clear-all-filters" class="text-xs text-primary-600 hover:text-primary-700 dark:hover:text-primary-400 font-medium ml-2">
                Clear all
              </button>
            </div>
          </div>
        </Card>
      </div>

      <!-- View Toggle -->
      <div class="flex items-center justify-between gap-3 mb-4">
        <p class="text-base text-gray-600 dark:text-zinc-400">
          Showing <span id="results-count-inline" class="font-semibold text-gray-700 dark:text-zinc-300">{totalTopics}</span> topic{totalTopics === 1 ? '' : 's'}
        </p>
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-500 dark:text-zinc-500">View:</span>
          <div class="flex border border-gray-300 dark:border-zinc-700 rounded-lg overflow-hidden">
          <button
            type="button"
            id="view-grid"
            class="view-toggle-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium bg-gray-200 dark:bg-zinc-700 text-gray-900 dark:text-zinc-100 border-r border-gray-300 dark:border-zinc-700"
            title="Grid view"
            aria-pressed="true"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
            </svg>
            <span class="hidden sm:inline">Grid</span>
          </button>
          <button
            type="button"
            id="view-list"
            class="view-toggle-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium bg-white dark:bg-zinc-900 text-gray-600 dark:text-zinc-400 hover:bg-gray-50 dark:bg-zinc-800/60"
            title="List view"
            aria-pressed="false"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <span class="hidden sm:inline">List</span>
          </button>
          </div>
        </div>
      </div>
    </div>

    <div id="topics-container" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
      {sortedTopics.map((topic) => {
        const categoryColors = getCategoryColors(topic.data.category);
        return (
          <a 
            href={`/topics/${topic.slug}`} 
            class="block topic-card group" 
            data-category={topic.data.category}
            data-title={topic.data.title.toLowerCase()}
            data-description={topic.data.description.toLowerCase()}
          >
            <Card class="topic-card-surface h-full border-gray-200/80 dark:border-zinc-800 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-gray-300 dark:hover:border-zinc-700">
              <CardHeader class="topic-card-header">
                <div class="topic-card-content">
                  <div class="topic-card-meta flex items-center justify-between gap-3 mb-2">
                    <span class={`inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded border ${categoryColors.bg} ${categoryColors.text} ${categoryColors.border}`}>
                      <CategoryIcon category={topic.data.category} class={`w-3 h-3 ${categoryColors.icon}`} />
                      {topic.data.category}
                    </span>
                    <svg class="topic-card-corner-arrow w-4 h-4 text-gray-400 dark:text-zinc-600 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                  <CardTitle class="topic-card-title mb-3 line-clamp-2 break-words leading-snug">{topic.data.title}</CardTitle>
                  <CardDescription class="topic-card-description line-clamp-3">{topic.data.description}</CardDescription>
                </div>
                <div class="topic-card-cta hidden mt-4">
                  <span class="inline-flex items-center gap-1.5 rounded-md border border-gray-200 bg-gray-50 px-3 py-1.5 text-sm font-medium text-gray-700 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-200">
                    Read topic
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </CardHeader>
            </Card>
          </a>
        );
      })}
    </div>

    <div id="no-results" class="hidden text-center py-12">
      <p class="text-gray-500 dark:text-zinc-500 text-lg">No topics found matching your search.</p>
    </div>

    <script>
      (function() {
        let searchInput: HTMLInputElement | null = null;
        let topicsContainer: HTMLElement | null = null;
        let noResults: HTMLElement | null = null;
        let topicCards: NodeListOf<Element> | null = null;
        let activeFilters: HTMLElement | null = null;
        let activeFilterTags: HTMLElement | null = null;
        let clearAllBtn: HTMLButtonElement | null = null;
        let tagFilterButtons: NodeListOf<Element> | null = null;
        let viewGridBtn: HTMLButtonElement | null = null;
        let viewListBtn: HTMLButtonElement | null = null;
        let filterToggleBtn: HTMLButtonElement | null = null;
        let filterTagsContent: HTMLElement | null = null;
        let filterToggleIcon: HTMLElement | null = null;
        let filterSelectedCount: HTMLElement | null = null;
        let resultsCountInline: HTMLElement | null = null;
        let resetFiltersBtn: HTMLButtonElement | null = null;

        const activeFiltersSet = new Set<string>();

        function updateResetButtonVisibility() {
          if (!resetFiltersBtn || !searchInput) return;
          const hasSearch = searchInput.value.trim().length > 0;
          const hasCategories = activeFiltersSet.size > 0;
          if (hasSearch || hasCategories) {
            resetFiltersBtn.classList.remove('hidden');
          } else {
            resetFiltersBtn.classList.add('hidden');
          }
        }

        function resetFilters() {
          if (searchInput) searchInput.value = '';
          clearAllFilters();
        }

        function toggleFilterTags() {
          if (!filterTagsContent || !filterToggleIcon || !filterToggleBtn) return;
          
          const isHidden = filterTagsContent.classList.contains('hidden');
          if (isHidden) {
            filterTagsContent.classList.remove('hidden');
            filterToggleIcon.classList.add('rotate-180');
            filterToggleBtn.setAttribute('aria-expanded', 'true');
          } else {
            filterTagsContent.classList.add('hidden');
            filterToggleIcon.classList.remove('rotate-180');
            filterToggleBtn.setAttribute('aria-expanded', 'false');
          }
        }

        function setGridView() {
          if (!topicsContainer) return;
          topicsContainer.classList.remove('flex', 'flex-col', 'gap-3');
          topicsContainer.classList.add('grid', 'sm:grid-cols-2', 'lg:grid-cols-3', 'gap-4', 'sm:gap-5');
          
          viewGridBtn?.classList.remove('bg-white', 'dark:bg-zinc-900', 'text-gray-600', 'dark:text-zinc-400', 'hover:bg-gray-50', 'dark:bg-zinc-800/60');
          viewGridBtn?.classList.add('bg-gray-200', 'dark:bg-zinc-700', 'text-gray-900', 'dark:text-zinc-100');
          viewListBtn?.classList.remove('bg-gray-200', 'dark:bg-zinc-700', 'text-gray-900', 'dark:text-zinc-100');
          viewListBtn?.classList.add('bg-white', 'dark:bg-zinc-900', 'text-gray-600', 'dark:text-zinc-400', 'hover:bg-gray-50', 'dark:bg-zinc-800/60');
          viewGridBtn?.setAttribute('aria-pressed', 'true');
          viewListBtn?.setAttribute('aria-pressed', 'false');

          topicCards?.forEach((card) => {
            card.classList.remove('w-full');
            const cardElement = card as HTMLElement;
            const surface = cardElement.querySelector('.topic-card-surface');
            const header = cardElement.querySelector('.topic-card-header');
            const content = cardElement.querySelector('.topic-card-content');
            const titleEl = cardElement.querySelector('.topic-card-title');
            const description = cardElement.querySelector('.topic-card-description');
            const cta = cardElement.querySelector('.topic-card-cta');
            const meta = cardElement.querySelector('.topic-card-meta');
            const cornerArrow = cardElement.querySelector('.topic-card-corner-arrow');

            surface?.classList.remove('sm:border-l-4', 'sm:border-l-gray-300', 'dark:sm:border-l-zinc-600', 'sm:hover:border-l-gray-400', 'dark:sm:hover:border-l-zinc-500', 'sm:bg-gray-50/40', 'dark:sm:bg-zinc-900/80');
            header?.classList.remove('sm:flex', 'sm:flex-row', 'sm:items-center', 'sm:justify-between', 'sm:gap-6');
            content?.classList.remove('sm:flex-1', 'sm:min-w-0');
            titleEl?.classList.remove('sm:mb-2');
            description?.classList.remove('sm:line-clamp-2', 'sm:max-w-3xl');
            meta?.classList.remove('sm:mb-1');
            cta?.classList.remove('sm:shrink-0', 'sm:ml-6', 'sm:mt-0', 'sm:self-center', 'sm:block');
            cta?.classList.add('hidden');
            cornerArrow?.classList.remove('hidden', 'sm:hidden');
          });
          
          localStorage.setItem('topics-view', 'grid');
        }

        function setListView() {
          if (!topicsContainer) return;
          topicsContainer.classList.remove('grid', 'sm:grid-cols-2', 'lg:grid-cols-3', 'gap-4');
          topicsContainer.classList.remove('sm:gap-5');
          topicsContainer.classList.add('flex', 'flex-col', 'gap-3');
          
          viewListBtn?.classList.remove('bg-white', 'dark:bg-zinc-900', 'text-gray-600', 'dark:text-zinc-400', 'hover:bg-gray-50', 'dark:bg-zinc-800/60');
          viewListBtn?.classList.add('bg-gray-200', 'dark:bg-zinc-700', 'text-gray-900', 'dark:text-zinc-100');
          viewGridBtn?.classList.remove('bg-gray-200', 'dark:bg-zinc-700', 'text-gray-900', 'dark:text-zinc-100');
          viewGridBtn?.classList.add('bg-white', 'dark:bg-zinc-900', 'text-gray-600', 'dark:text-zinc-400', 'hover:bg-gray-50', 'dark:bg-zinc-800/60');
          viewListBtn?.setAttribute('aria-pressed', 'true');
          viewGridBtn?.setAttribute('aria-pressed', 'false');

          topicCards?.forEach((card) => {
            card.classList.add('w-full');
            const cardElement = card as HTMLElement;
            const surface = cardElement.querySelector('.topic-card-surface');
            const header = cardElement.querySelector('.topic-card-header');
            const content = cardElement.querySelector('.topic-card-content');
            const titleEl = cardElement.querySelector('.topic-card-title');
            const description = cardElement.querySelector('.topic-card-description');
            const cta = cardElement.querySelector('.topic-card-cta');
            const meta = cardElement.querySelector('.topic-card-meta');
            const cornerArrow = cardElement.querySelector('.topic-card-corner-arrow');

            surface?.classList.add('sm:border-l-4', 'sm:border-l-gray-300', 'dark:sm:border-l-zinc-600', 'sm:hover:border-l-gray-400', 'dark:sm:hover:border-l-zinc-500', 'sm:bg-gray-50/40', 'dark:sm:bg-zinc-900/80');
            header?.classList.add('sm:flex', 'sm:flex-row', 'sm:items-center', 'sm:justify-between', 'sm:gap-8');
            content?.classList.add('sm:flex-1', 'sm:min-w-0');
            titleEl?.classList.add('sm:mb-2');
            description?.classList.add('sm:line-clamp-2', 'sm:max-w-3xl');
            meta?.classList.add('sm:mb-1');
            cta?.classList.add('sm:shrink-0', 'sm:ml-6', 'sm:mt-0', 'sm:self-center', 'sm:block');
            cta?.classList.remove('hidden');
            cornerArrow?.classList.add('hidden', 'sm:hidden');
          });
          
          localStorage.setItem('topics-view', 'list');
        }

        function updateActiveFiltersDisplay() {
          if (!activeFilters || !activeFilterTags) return;

          if (activeFiltersSet.size === 0) {
            activeFilters.classList.add('hidden');
          } else {
            activeFilters.classList.remove('hidden');
            activeFilterTags.innerHTML = '';

            activeFiltersSet.forEach(tagKey => {
              const [type, value, label] = tagKey.split(':');
              const tag = document.createElement('button');
              tag.type = 'button';
              tag.className = 'inline-flex items-center gap-1.5 px-3 py-1.5 bg-primary-100 text-primary-900 rounded-lg text-xs font-medium border border-primary-300 hover:bg-primary-200 transition-colors';
              tag.innerHTML = `
                <span>${label}</span>
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              `;
              tag.addEventListener('click', () => {
                removeFilter(type, value);
              });
              activeFilterTags.appendChild(tag);
            });
          }

          if (filterSelectedCount) {
            const count = activeFiltersSet.size;
            if (count > 0) {
              filterSelectedCount.textContent = String(count);
              filterSelectedCount.classList.remove('hidden');
              filterSelectedCount.classList.add('inline-flex');
            } else {
              filterSelectedCount.textContent = '';
              filterSelectedCount.classList.add('hidden');
              filterSelectedCount.classList.remove('inline-flex');
            }
          }
        }

        function addFilter(type: string, value: string, label: string) {
          const tagKey = `${type}:${value}:${label}`;
          activeFiltersSet.add(tagKey);
          updateActiveFiltersDisplay();
          updateTagButtons();
          performFilter();
        }

        function removeFilter(type: string, value: string) {
          const tagKey = Array.from(activeFiltersSet).find(key => key.startsWith(`${type}:${value}:`));
          if (tagKey) {
            activeFiltersSet.delete(tagKey);
            updateActiveFiltersDisplay();
            updateTagButtons();
            performFilter();
          }
        }

        function clearAllFilters() {
          activeFiltersSet.clear();
          updateActiveFiltersDisplay();
          updateTagButtons();
          performFilter();
        }

        function updateTagButtons() {
          if (!tagFilterButtons) return;
          tagFilterButtons.forEach(btn => {
            const type = (btn as HTMLElement).dataset.tagType || '';
            const value = (btn as HTMLElement).dataset.tagValue || '';
            const tagKey = Array.from(activeFiltersSet).find(key => key.startsWith(`${type}:${value}:`));
            
            if (tagKey) {
              btn.classList.add('ring-2', 'ring-primary-500', 'ring-offset-2');
            } else {
              btn.classList.remove('ring-2', 'ring-primary-500', 'ring-offset-2');
            }
          });
        }

        function performFilter() {
          if (!topicsContainer || !noResults || !topicCards || topicCards.length === 0) {
            return;
          }

          const searchQuery = searchInput?.value.toLowerCase().trim() || '';
          const activeCategories = new Set<string>();

          activeFiltersSet.forEach(tagKey => {
            const [type, value] = tagKey.split(':');
            if (type === 'category') {
              activeCategories.add(value);
            }
          });

          let visibleCount = 0;

          topicCards.forEach(card => {
            const cardElement = card as HTMLElement;
            const category = cardElement.dataset.category || '';
            const title = cardElement.dataset.title || '';
            const description = cardElement.dataset.description || '';

            const matchesSearch = !searchQuery || 
              title.includes(searchQuery) || 
              description.includes(searchQuery);

            const matchesCategory = activeCategories.size === 0 || activeCategories.has(category);

            if (matchesSearch && matchesCategory) {
              cardElement.style.display = 'block';
              visibleCount++;
            } else {
              cardElement.style.display = 'none';
            }
          });

          if (visibleCount === 0) {
            topicsContainer.classList.add('hidden');
            noResults.classList.remove('hidden');
          } else {
            topicsContainer.classList.remove('hidden');
            noResults.classList.add('hidden');
          }

          if (resultsCountInline) {
            resultsCountInline.textContent = String(visibleCount);
          }

          updateResetButtonVisibility();
        }

        function initSearch() {
          searchInput = document.getElementById('search-input') as HTMLInputElement;
          topicsContainer = document.getElementById('topics-container');
          noResults = document.getElementById('no-results');
          topicCards = document.querySelectorAll('.topic-card');
          activeFilters = document.getElementById('active-filters');
          activeFilterTags = document.getElementById('active-filter-tags');
          clearAllBtn = document.getElementById('clear-all-filters') as HTMLButtonElement;
          tagFilterButtons = document.querySelectorAll('.tag-filter-btn');
          viewGridBtn = document.getElementById('view-grid') as HTMLButtonElement;
          viewListBtn = document.getElementById('view-list') as HTMLButtonElement;
          filterToggleBtn = document.getElementById('filter-toggle-btn') as HTMLButtonElement;
          filterTagsContent = document.getElementById('filter-tags-content');
          filterToggleIcon = document.getElementById('filter-toggle-icon');
          filterSelectedCount = document.getElementById('filter-selected-count');
          resultsCountInline = document.getElementById('results-count-inline');
          resetFiltersBtn = document.getElementById('reset-filters-btn') as HTMLButtonElement;

          if (!searchInput || !topicsContainer || !noResults || !topicCards || topicCards.length === 0) {
            setTimeout(initSearch, 100);
            return;
          }

          searchInput.addEventListener('input', performFilter);

          tagFilterButtons.forEach(btn => {
            btn.addEventListener('click', () => {
              const type = (btn as HTMLElement).dataset.tagType || '';
              const value = (btn as HTMLElement).dataset.tagValue || '';
              const label = (btn as HTMLElement).dataset.tagLabel || '';

              const tagKey = Array.from(activeFiltersSet).find(key => key.startsWith(`${type}:${value}:`));
              if (tagKey) {
                removeFilter(type, value);
              } else {
                addFilter(type, value, label);
              }
            });
          });

          if (clearAllBtn) {
            clearAllBtn.addEventListener('click', clearAllFilters);
          }

          resetFiltersBtn?.addEventListener('click', resetFilters);

          filterToggleBtn?.addEventListener('click', toggleFilterTags);
          viewGridBtn?.addEventListener('click', setGridView);
          viewListBtn?.addEventListener('click', setListView);

          const savedView = localStorage.getItem('topics-view');
          if (savedView === 'list') {
            setListView();
          }

          updateActiveFiltersDisplay();
          performFilter();
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initSearch);
        } else {
          initSearch();
        }
      })();
    </script>
  </div>
</BaseLayout>
