---
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/600.css';
import '@fontsource/dm-sans/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/600.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/markdown.css';
import '../styles/theme.css';
import { features } from '../config/features';
import { site } from '../config/site';
import { toMetaDescription } from '../utils/meta';

interface Props {
  title: string;
  description?: string;
  image?: string;
  /** Open Graph type — use `article` for topic/glossary entries */
  ogType?: 'website' | 'article';
  /** Shown as `article:section` when `ogType` is `article` */
  section?: string;
  /** Accessible label for the preview image */
  imageAlt?: string;
  /** ISO datetime for article publishing time */
  publishedTime?: string;
  /** ISO datetime for article updated time */
  modifiedTime?: string;
}

const {
  title,
  description: descriptionProp,
  image = site.ogImage,
  ogType = 'website',
  section,
  imageAlt,
  publishedTime,
  modifiedTime,
} = Astro.props;

const metaDescription = toMetaDescription(descriptionProp ?? site.description);
const resolvedImageAlt = (imageAlt ?? `${title} — ${site.name}`).slice(0, 200);

const currentYear = new Date().getFullYear();
const gaId = site.googleAnalyticsId;
const canonicalUrl = new URL(Astro.url.pathname, site.url).href;
const ogImageUrl = new URL(image, site.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={metaDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)" />
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var storedTheme = null;
        try {
          storedTheme = localStorage.getItem('theme');
        } catch (e) {
          storedTheme = null;
        }
        var dark = storedTheme
          ? storedTheme === 'dark'
          : window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (dark) root.classList.add('dark');
        else root.classList.remove('dark');
        root.style.colorScheme = dark ? 'dark' : 'light';
        document.addEventListener('astro:after-swap', function () {
          var nextStoredTheme = null;
          try {
            nextStoredTheme = localStorage.getItem('theme');
          } catch (e) {
            nextStoredTheme = null;
          }
          var nextDark = nextStoredTheme
            ? nextStoredTheme === 'dark'
            : window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.classList.toggle('dark', nextDark);
          document.documentElement.style.colorScheme = nextDark ? 'dark' : 'light';
        });
      })();
    </script>


    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    
    <!-- Android Chrome Icons -->
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={resolvedImageAlt} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />
    {ogType === 'article' && section && (
      <meta property="article:section" content={section} />
    )}
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={resolvedImageAlt} />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": site.name,
      "url": site.url,
      "description": site.description,
      "publisher": {
        "@type": "Organization",
        "name": site.name,
        "url": site.url
      }
    })} />
    {ogType === 'article' && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Article",
          "headline": title,
          "description": metaDescription,
          "image": [ogImageUrl],
          "author": {
            "@type": "Person",
            "name": "myugan"
          },
          "publisher": {
            "@type": "Organization",
            "name": site.name,
            "url": site.url
          },
          "datePublished": publishedTime,
          "dateModified": modifiedTime ?? publishedTime,
          "mainEntityOfPage": canonicalUrl
        })}
      />
    )}
    
    <title>{title}</title>
    
    <!-- Google Analytics -->
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body class="ks-theme antialiased flex flex-col min-h-screen font-sans selection:bg-emerald-200/60 selection:text-emerald-900 dark:selection:bg-emerald-500/25 dark:selection:text-emerald-100">
    <div id="page-skeleton" class="fixed inset-0 z-[70] bg-app-bg transition-opacity duration-200 pointer-events-none">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="h-10 w-48 rounded-md bg-app-surface-muted/80 animate-pulse"></div>
      </div>
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-4">
        <div class="h-8 w-72 rounded-md bg-app-surface-muted/80 animate-pulse"></div>
        <div class="h-4 w-full rounded-md bg-app-surface-muted/70 animate-pulse"></div>
        <div class="h-4 w-11/12 rounded-md bg-app-surface-muted/70 animate-pulse"></div>
        <div class="h-4 w-9/12 rounded-md bg-app-surface-muted/70 animate-pulse"></div>
      </div>
    </div>
    <header class="ks-header sticky top-0 z-50 border-b backdrop-blur-md dark:ring-1 dark:ring-zinc-700/60">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <a href="/glossary" class="flex items-center flex-shrink-0">
            <img src="/logo.png" alt="Kubernetes Security" class="h-8" />
          </a>
          
          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-6">
            <a href="/glossary" class="ks-nav-link transition-colors">Glossary</a>
            <a href="/topics" class="ks-nav-link transition-colors">Topics</a>
            <a href="/techniques" class="ks-nav-link transition-colors">ATT&amp;CK Map</a>
            {features.attackPaths && (
              <a href="/attack-paths" class="ks-nav-link transition-colors">Attack Paths</a>
            )}
            <a href="/tools" class="ks-nav-link transition-colors">Tools</a>
            <span class="ks-nav-muted inline-flex items-center gap-2">
              <span>Cheatsheet</span>
              <span class="inline-flex items-center rounded-full border border-amber-300 bg-amber-50 px-2 py-0.5 text-[10px] font-semibold tracking-wide text-amber-700 dark:border-amber-700/70 dark:bg-amber-950/40 dark:text-amber-300">
                Soon
              </span>
            </span>
            <a href="/" class="ks-nav-link transition-colors">About</a>
            <button
              type="button"
              id="theme-toggle-desktop"
              class="theme-toggle-btn ks-theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-full border transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500/40 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-zinc-900"
              aria-label="Toggle theme"
              aria-pressed="false"
              title="Toggle theme"
            >
              <svg data-icon="sun" class="h-4 w-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364 6.364l-1.414-1.414M7.05 7.05 5.636 5.636m12.728 0L16.95 7.05M7.05 16.95l-1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z" />
              </svg>
              <svg data-icon="moon" class="h-4 w-4 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3c0 .35.02.7.06 1.04A7 7 0 0020 11.73c.34.04.69.06 1 .06z" />
              </svg>
            </button>
          </div>

          <div class="flex items-center gap-2 md:hidden">
          <button
            type="button"
            id="theme-toggle-mobile"
            class="theme-toggle-btn ks-theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-full border transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500/40 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-zinc-900"
            aria-label="Toggle theme"
            aria-pressed="false"
            title="Toggle theme"
          >
            <svg data-icon="sun" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364 6.364l-1.414-1.414M7.05 7.05 5.636 5.636m12.728 0L16.95 7.05M7.05 16.95l-1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z" />
            </svg>
            <svg data-icon="moon" class="w-5 h-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3c0 .35.02.7.06 1.04A7 7 0 0020 11.73c.34.04.69.06 1 .06z" />
            </svg>
          </button>
          <!-- Mobile Menu Button -->
          <button 
            type="button" 
            id="mobile-menu-btn"
            class="p-2 rounded-lg ks-nav-link hover:bg-app-surface-muted/70 transition-colors"
            aria-label="Open menu"
          >
            <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          </div>
        </div>
        
        <!-- Mobile Navigation -->
        <div id="mobile-menu" class="ks-mobile-menu hidden md:hidden border-t py-3">
          <div class="space-y-0.5">
            <a href="/glossary" class="ks-nav-link block px-3 py-2 rounded-lg hover:bg-app-surface-muted/70 transition-colors">
              Glossary
            </a>
            <a href="/topics" class="ks-nav-link block px-3 py-2 rounded-lg hover:bg-app-surface-muted/70 transition-colors">
              Topics
            </a>
            <a href="/techniques" class="ks-nav-link block px-3 py-2 rounded-lg hover:bg-app-surface-muted/70 transition-colors">
              ATT&amp;CK Map
            </a>
            {features.attackPaths && (
              <a href="/attack-paths" class="ks-nav-link block px-3 py-2 rounded-lg hover:bg-app-surface-muted/70 transition-colors">
                Attack Paths
              </a>
            )}
            <a href="/tools" class="ks-nav-link block px-3 py-2 rounded-lg hover:bg-app-surface-muted/70 transition-colors">
              Tools
            </a>
            <div class="ks-nav-muted flex items-center justify-between px-3 py-2 rounded-lg">
              <span>Cheatsheet</span>
              <span class="inline-flex items-center rounded-full border border-amber-300 bg-amber-50 px-2 py-0.5 text-[10px] font-semibold tracking-wide text-amber-700 dark:border-amber-700/70 dark:bg-amber-950/40 dark:text-amber-300">
                Soon
              </span>
            </div>
            <a href="/" class="ks-nav-link block px-3 py-2 rounded-lg hover:bg-app-surface-muted/70 transition-colors">
              About
            </a>
          </div>
        </div>
      </nav>
    </header>
    <main class="flex-grow">
      <slot />
    </main>
    <footer class="ks-footer mt-auto border-t py-10 dark:ring-1 dark:ring-zinc-700/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 md:grid-cols-2 md:items-start">
          <div>
            <p class="text-sm font-semibold ds-text-primary">Kubernetes Security</p>
            <p class="mt-2 text-sm ds-text-secondary max-w-sm">
              Practical offensive and defensive references to help you learn Kubernetes security faster.
            </p>
          </div>

          <div class="md:text-right">
            <p class="text-sm ds-text-secondary">
              Built by
              <a href="https://www.linkedin.com/in/muhammadyugan/" target="_blank" rel="noopener noreferrer" class="ds-link hover:underline">
                myugan
              </a>
            </p>
            <p class="mt-2 text-xs ds-text-muted">© {currentYear} kubernetes-security.cloud</p>
          </div>
        </div>
      </div>
    </footer>
    
    <script>
      const pageSkeleton = document.getElementById('page-skeleton');

      function hideSkeleton() {
        if (!pageSkeleton) return;
        pageSkeleton.classList.add('opacity-0');
        window.setTimeout(() => {
          pageSkeleton.classList.add('hidden');
        }, 220);
      }

      function showSkeleton() {
        if (!pageSkeleton) return;
        pageSkeleton.classList.remove('hidden', 'opacity-0');
      }

      // Hide on initial load.
      if (document.readyState === 'complete') {
        hideSkeleton();
      } else {
        window.addEventListener('load', hideSkeleton, { once: true });
      }

      // Show skeleton during Astro view transitions and hide when swapped.
      document.addEventListener('astro:before-preparation', showSkeleton);
      document.addEventListener('astro:after-swap', hideSkeleton);

      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');
      
      if (mobileMenuBtn && mobileMenu && menuIcon && closeIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          const isOpen = !mobileMenu.classList.contains('hidden');
          
          if (isOpen) {
            mobileMenu.classList.add('hidden');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
          } else {
            mobileMenu.classList.remove('hidden');
            menuIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
          }
        });
        
        // Close menu when clicking a link
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
          });
        });
      }

      let themeTransitionCleanupTimer = null;

      function applyTheme(theme) {
        const dark = theme === 'dark';
        const root = document.documentElement;
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!prefersReducedMotion) {
          if (themeTransitionCleanupTimer) {
            window.clearTimeout(themeTransitionCleanupTimer);
          }
          root.classList.add('theme-transitioning');
          themeTransitionCleanupTimer = window.setTimeout(() => {
            root.classList.remove('theme-transitioning');
            themeTransitionCleanupTimer = null;
          }, 360);
        }
        // Wait a frame so transition styles are applied before theme flips.
        if (!prefersReducedMotion) {
          window.requestAnimationFrame(() => {
            root.classList.toggle('dark', dark);
            root.style.colorScheme = dark ? 'dark' : 'light';
          });
        } else {
          root.classList.toggle('dark', dark);
          root.style.colorScheme = dark ? 'dark' : 'light';
        }
        try {
          localStorage.setItem('theme', theme);
        } catch (e) {
          // Ignore storage errors in restricted environments.
        }
        document.querySelectorAll('.theme-toggle-btn').forEach((button) => {
          button.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
          button.setAttribute('title', dark ? 'Switch to light mode' : 'Switch to dark mode');
          button.setAttribute('aria-pressed', dark ? 'true' : 'false');
        });
      }

      function toggleTheme() {
        const isDark = document.documentElement.classList.contains('dark');
        applyTheme(isDark ? 'light' : 'dark');
      }

      document.querySelectorAll('.theme-toggle-btn').forEach((button) => {
        button.addEventListener('click', toggleTheme);
      });
      const initialDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.theme-toggle-btn').forEach((button) => {
        button.setAttribute('aria-label', initialDark ? 'Switch to light mode' : 'Switch to dark mode');
        button.setAttribute('title', initialDark ? 'Switch to light mode' : 'Switch to dark mode');
        button.setAttribute('aria-pressed', initialDark ? 'true' : 'false');
      });

      // Follow system changes only when user has not chosen a theme explicitly.
      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      function syncWithSystemTheme(event) {
        let hasStoredTheme = false;
        try {
          hasStoredTheme = Boolean(localStorage.getItem('theme'));
        } catch (e) {
          hasStoredTheme = false;
        }
        if (hasStoredTheme) return;
        const nextTheme = event.matches ? 'dark' : 'light';
        applyTheme(nextTheme);
        try {
          localStorage.removeItem('theme');
        } catch (e) {
          // Ignore storage errors.
        }
      }
      if (typeof mediaQuery.addEventListener === 'function') {
        mediaQuery.addEventListener('change', syncWithSystemTheme);
      } else if (typeof mediaQuery.addListener === 'function') {
        mediaQuery.addListener(syncWithSystemTheme);
      }

      // Add copy buttons to command code blocks (not output blocks)
      function addCopyButtons() {
        const codeBlocks = document.querySelectorAll('pre[data-language="bash"], pre[data-language="shell"], pre[data-language="sh"], pre[data-language="yaml"], pre[data-language="json"]');
        
        codeBlocks.forEach((pre) => {
          // Skip if already has a copy button
          if (pre.querySelector('.copy-button')) return;

          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'copy-button';
          button.setAttribute('aria-label', 'Copy code');
          button.setAttribute('title', 'Copy');
          button.innerHTML = `
            <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <svg class="check-icon hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          `;

          const copyIcon = button.querySelector('.copy-icon');
          const checkIcon = button.querySelector('.check-icon');

          button.addEventListener('click', async () => {
            const code = pre.querySelector('code');
            if (!code) return;
            try {
              await navigator.clipboard.writeText(code.textContent || '');
              copyIcon.classList.add('hidden');
              checkIcon.classList.remove('hidden');
              button.classList.add('copied');
              button.setAttribute('aria-label', 'Copied');
              button.setAttribute('title', 'Copied');

              window.setTimeout(() => {
                copyIcon.classList.remove('hidden');
                checkIcon.classList.add('hidden');
                button.classList.remove('copied');
                button.setAttribute('aria-label', 'Copy code');
                button.setAttribute('title', 'Copy');
              }, 2000);
            } catch (err) {
              console.error('Failed to copy:', err);
            }
          });

          pre.appendChild(button);
        });
      }
      
      // Run on page load
      addCopyButtons();

      // Also run after view transitions (if using)
      document.addEventListener('astro:after-swap', addCopyButtons);
    </script>
  </body>
</html>
