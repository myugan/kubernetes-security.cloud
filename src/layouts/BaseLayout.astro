---
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/600.css';
import '@fontsource/geist-sans/700.css';
import '@fontsource/geist-mono/400.css';
import '@fontsource/geist-mono/500.css';
import '@fontsource/geist-mono/600.css';
import '@fontsource/geist-mono/700.css';
import '../styles/markdown.css';
import { features } from '../config/features';
import { site } from '../config/site';
import { toMetaDescription } from '../utils/meta';

interface Props {
  title: string;
  description?: string;
  image?: string;
  /** Open Graph type — use `article` for topic/glossary entries */
  ogType?: 'website' | 'article';
  /** Shown as `article:section` when `ogType` is `article` */
  section?: string;
  /** Accessible label for the preview image */
  imageAlt?: string;
}

const {
  title,
  description: descriptionProp,
  image = site.ogImage,
  ogType = 'website',
  section,
  imageAlt,
} = Astro.props;

const metaDescription = toMetaDescription(descriptionProp ?? site.description);
const resolvedImageAlt = (imageAlt ?? `${title} — ${site.name}`).slice(0, 200);

const currentYear = new Date().getFullYear();
const gaId = site.googleAnalyticsId;
const canonicalUrl = new URL(Astro.url.pathname, site.url).href;
const ogImageUrl = new URL(image, site.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (function () {
        function applyColorScheme() {
          var dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var root = document.documentElement;
          if (dark) root.classList.add('dark');
          else root.classList.remove('dark');
          root.style.colorScheme = dark ? 'dark' : 'light';
        }
        applyColorScheme();
        document.addEventListener('astro:after-swap', applyColorScheme);
        try {
          window
            .matchMedia('(prefers-color-scheme: dark)')
            .addEventListener('change', applyColorScheme);
        } catch (e) {
          window.matchMedia('(prefers-color-scheme: dark)').addListener(applyColorScheme);
        }
      })();
    </script>
    
    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    
    <!-- Android Chrome Icons -->
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={resolvedImageAlt} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />
    {ogType === 'article' && section && (
      <meta property="article:section" content={section} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={resolvedImageAlt} />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": site.name,
      "url": site.url,
      "description": site.description,
      "publisher": {
        "@type": "Organization",
        "name": site.name,
        "url": site.url
      }
    })} />
    
    <title>{title}</title>
    
    <!-- Google Analytics -->
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body class="bg-white text-gray-900 dark:bg-[#0c0c0e] dark:text-zinc-300 antialiased flex flex-col min-h-screen font-sans selection:bg-emerald-200/60 selection:text-emerald-900 dark:selection:bg-emerald-500/25 dark:selection:text-emerald-100">
    <header class="bg-white/95 dark:bg-[#0c0c0e]/95 backdrop-blur-sm border-b border-gray-200 dark:border-zinc-800 sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <a href="/glossary" class="flex items-center flex-shrink-0">
            <img src="/logo.png" alt="Kubernetes Security" class="h-8" />
          </a>
          
          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-6">
            <a href="/glossary" class="text-gray-600 hover:text-primary-600 dark:text-zinc-500 dark:hover:text-primary-400 transition-colors">Glossary</a>
            <a href="/topics" class="text-gray-600 hover:text-primary-600 dark:text-zinc-500 dark:hover:text-primary-400 transition-colors">Topics</a>
            {features.attackPaths && (
              <a href="/attack-paths" class="text-gray-600 hover:text-primary-600 dark:text-zinc-500 dark:hover:text-primary-400 transition-colors">Attack Paths</a>
            )}
            <a href="/tools" class="text-gray-600 hover:text-primary-600 dark:text-zinc-500 dark:hover:text-primary-400 transition-colors">Tools</a>
            <span class="inline-flex items-center gap-2 text-gray-500 dark:text-zinc-500">
              <span>Cheatsheet</span>
              <span class="inline-flex items-center rounded-full border border-amber-300 bg-amber-50 px-2 py-0.5 text-[10px] font-semibold tracking-wide text-amber-700 dark:border-amber-700/70 dark:bg-amber-950/40 dark:text-amber-300">
                Soon
              </span>
            </span>
            <a
              href="https://kubernetes-threat-matrix.redguard.ch/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-gray-600 hover:text-primary-600 dark:text-zinc-500 dark:hover:text-primary-400 transition-colors"
              title="Kubernetes Threat Matrix (MITRE ATT&amp;CK-style) — Redguard"
            >
              MITRE ATT&amp;CK
              <svg class="w-3.5 h-3.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
            <a href="/" class="text-gray-600 hover:text-primary-600 dark:text-zinc-500 dark:hover:text-primary-400 transition-colors">About</a>
          </div>

          <div class="flex items-center md:hidden">
          <!-- Mobile Menu Button -->
          <button 
            type="button" 
            id="mobile-menu-btn"
            class="p-2 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 dark:text-zinc-500 dark:hover:text-zinc-100 dark:hover:bg-zinc-800 transition-colors"
            aria-label="Open menu"
          >
            <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          </div>
        </div>
        
        <!-- Mobile Navigation -->
        <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 dark:border-zinc-800">
          <div class="py-3 space-y-1">
            <a href="/glossary" class="block px-3 py-2 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 dark:text-zinc-500 dark:hover:text-zinc-100 dark:hover:bg-zinc-800/80 transition-colors">
              Glossary
            </a>
            <a href="/topics" class="block px-3 py-2 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 dark:text-zinc-500 dark:hover:text-zinc-100 dark:hover:bg-zinc-800/80 transition-colors">
              Topics
            </a>
            {features.attackPaths && (
              <a href="/attack-paths" class="block px-3 py-2 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 dark:text-zinc-500 dark:hover:text-zinc-100 dark:hover:bg-zinc-800/80 transition-colors">
                Attack Paths
              </a>
            )}
            <a href="/tools" class="block px-3 py-2 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 dark:text-zinc-500 dark:hover:text-zinc-100 dark:hover:bg-zinc-800/80 transition-colors">
              Tools
            </a>
            <div class="flex items-center justify-between px-3 py-2 rounded-lg text-gray-600 dark:text-zinc-500">
              <span>Cheatsheet</span>
              <span class="inline-flex items-center rounded-full border border-amber-300 bg-amber-50 px-2 py-0.5 text-[10px] font-semibold tracking-wide text-amber-700 dark:border-amber-700/70 dark:bg-amber-950/40 dark:text-amber-300">
                Soon
              </span>
            </div>
            <a
              href="https://kubernetes-threat-matrix.redguard.ch/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 dark:text-zinc-500 dark:hover:text-zinc-100 dark:hover:bg-zinc-800/80 transition-colors"
              title="Kubernetes Threat Matrix (MITRE ATT&amp;CK-style) — Redguard"
            >
              MITRE ATT&amp;CK
              <svg class="w-3.5 h-3.5 opacity-70 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
            <a href="/" class="block px-3 py-2 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 dark:text-zinc-500 dark:hover:text-zinc-100 dark:hover:bg-zinc-800/80 transition-colors">
              About
            </a>
          </div>
        </div>
      </nav>
    </header>
    <main class="flex-grow">
      <slot />
    </main>
    <footer class="bg-white dark:bg-[#0c0c0e] border-t border-gray-200 dark:border-zinc-800 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <p class="text-center text-gray-500 dark:text-zinc-600 text-sm">
          © {currentYear} kubernetes-security.cloud · Made by <a href="https://www.linkedin.com/in/muhammadyugan/" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 hover:underline">myugan</a>
        </p>
      </div>
    </footer>
    
    <script>
      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');
      
      if (mobileMenuBtn && mobileMenu && menuIcon && closeIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          const isOpen = !mobileMenu.classList.contains('hidden');
          
          if (isOpen) {
            mobileMenu.classList.add('hidden');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
          } else {
            mobileMenu.classList.remove('hidden');
            menuIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
          }
        });
        
        // Close menu when clicking a link
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
          });
        });
      }

      // Add copy buttons to command code blocks (not output blocks)
      function addCopyButtons() {
        const codeBlocks = document.querySelectorAll('pre[data-language="bash"], pre[data-language="shell"], pre[data-language="sh"], pre[data-language="yaml"], pre[data-language="json"]');
        
        codeBlocks.forEach((pre) => {
          // Skip if already has a copy button
          if (pre.querySelector('.copy-button')) return;

          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'copy-button';
          button.setAttribute('aria-label', 'Copy code');
          button.setAttribute('title', 'Copy');
          button.innerHTML = `
            <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <svg class="check-icon hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          `;

          const copyIcon = button.querySelector('.copy-icon');
          const checkIcon = button.querySelector('.check-icon');

          button.addEventListener('click', async () => {
            const code = pre.querySelector('code');
            if (!code) return;
            try {
              await navigator.clipboard.writeText(code.textContent || '');
              copyIcon.classList.add('hidden');
              checkIcon.classList.remove('hidden');
              button.classList.add('copied');
              button.setAttribute('aria-label', 'Copied');
              button.setAttribute('title', 'Copied');

              window.setTimeout(() => {
                copyIcon.classList.remove('hidden');
                checkIcon.classList.add('hidden');
                button.classList.remove('copied');
                button.setAttribute('aria-label', 'Copy code');
                button.setAttribute('title', 'Copy');
              }, 2000);
            } catch (err) {
              console.error('Failed to copy:', err);
            }
          });

          pre.appendChild(button);
        });
      }
      
      // Run on page load
      addCopyButtons();
      
      // Also run after view transitions (if using)
      document.addEventListener('astro:after-swap', addCopyButtons);
    </script>
  </body>
</html>
