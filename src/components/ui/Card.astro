---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class={`ds-surface rounded-2xl border shadow-[0_10px_30px_-18px_rgba(2,6,23,0.28)] dark:shadow-[0_20px_44px_-24px_rgba(2,6,23,0.9)] ring-1 ring-black/[0.02] dark:ring-app-border/50 backdrop-blur-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_16px_36px_-18px_rgba(2,6,23,0.34)] dark:hover:shadow-[0_24px_50px_-24px_rgba(2,6,23,0.95)] ${className}`}>
  <slot />
</div>
